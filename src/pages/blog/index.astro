---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const base = import.meta.env.BASE_URL;
---

<Layout title="Blog — El Mahdi Moubarak" description="Articles on engineering, SaaS, AI, and shipping products.">
  <section class="mb-8">
    <h1 class="text-2xl font-extrabold mb-1">Blog</h1>
    <p class="font-mono text-xs text-muted">
      Metaphysics of code, life, and everything in between.
    </p>
  </section>

  {sortedPosts.length === 0 ? (
    <div class="b-border p-8 text-center bg-paper dark:bg-dark-surface">
      <p class="font-mono text-sm text-muted">Nothing here yet.</p>
    </div>
  ) : (
    <div class="space-y-3">
      {sortedPosts.map((post) => (
        <a href={`${base}blog/${post.id}`} class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-1 sm:gap-4 py-3 border-b border-ink/10 dark:border-dark-border group">
          <div class="flex-1 min-w-0">
            <span class="font-mono text-sm font-bold group-hover:text-accent transition-colors block truncate">{post.data.title}</span>
            <span class="text-xs text-muted line-clamp-1">{post.data.description}</span>
          </div>
          <span class="font-mono text-[0.65rem] text-muted shrink-0">
            {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </span>
        </a>
      ))}
    </div>
  )}
</Layout>
