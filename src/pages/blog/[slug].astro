---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
---

<Layout title={`${post.data.title} — El Mahdi Moubarak`} description={post.data.description}>
  <article>
    <header class="mb-10">
      <a href={`${base}blog`} class="font-mono text-xs text-muted hover:text-accent transition-colors mb-6 inline-block">
        ← back
      </a>
      <h1 class="text-2xl md:text-3xl font-extrabold leading-tight mb-3">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap items-center gap-3">
        <time class="font-mono text-xs text-muted" datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {post.data.tags.length > 0 && (
          <>
            <span class="text-muted">·</span>
            <div class="flex flex-wrap gap-1.5">
              {post.data.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </>
        )}
      </div>
    </header>

    <div class="prose-content">
      <Content />
    </div>

    <footer class="mt-12 pt-6 border-t-2 border-ink dark:border-dark-border">
      <a href={`${base}blog`} class="font-mono text-xs text-muted hover:text-accent transition-colors">
        ← all posts
      </a>
    </footer>
  </article>
</Layout>
